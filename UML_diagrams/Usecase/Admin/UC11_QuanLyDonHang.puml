@startuml UC11_QuanLyDonHang
!theme plain
skinparam backgroundColor #FAFAFA
skinparam defaultFontName Arial

skinparam actor {
    BorderColor #784212
    BackgroundColor #FAD7A0
    FontColor #1A252F
    FontSize 13
    FontStyle bold
}

skinparam usecase {
    BorderColor #E67E22
    BackgroundColor #FEF5E7
    FontColor #1A252F
    FontSize 12
    ArrowColor #5D6D7E
}

skinparam rectangle {
    BorderColor #E67E22
    BorderThickness 2
    BackgroundColor #FDFEFE
    FontColor #784212
    FontSize 14
    FontStyle bold
}

title <size:17><b>UC11 - Quản Lý Đơn Hàng (Admin)</b></size>\n<color:#5D6D7E><size:12>CellphoneK E-Commerce App</size></color>

' ===================== ACTORS =====================
actor "Quản Trị Viên\n(Admin)" as Admin
actor "Khách Hàng\n(Customer)" as Customer

' ===================== SYSTEM BOUNDARY =====================
rectangle "Hệ Thống Quản Lý Đơn Hàng" {
    usecase "UC11.1\nXem tất cả đơn hàng\n(Lọc theo trạng thái,\nphân trang)" as UC11_1
    usecase "UC11.2\nCập nhật trạng thái\nđơn hàng" as UC11_2
    usecase "UC11.3\nGửi thông báo\ncho khách hàng\n(Khi DELIVERED)" as UC11_3
}

' ===================== ASSOCIATIONS =====================
Admin --> UC11_1
Admin --> UC11_2
Customer ..> UC11_3 : Nhận thông báo

' ===================== RELATIONSHIPS =====================
UC11_2 .> UC11_1 : <<include>>
UC11_2 .> UC11_3 : <<include>>

' ===================== NOTES =====================
note right of UC11_2
  Luồng trạng thái đơn hàng:
  NEW → CONFIRMED → PREPARING
  → SHIPPING → DELIVERED
                ↓
           CANCELLED
end note

note right of UC11_3
  Tự động khi Admin chuyển
  trạng thái sang DELIVERED:
  - Cộng soldQuantity sản phẩm
  - Gửi thông báo trong app
    cho khách hàng
end note

@enduml
