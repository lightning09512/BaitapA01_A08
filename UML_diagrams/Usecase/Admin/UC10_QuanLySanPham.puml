@startuml UC10_QuanLySanPham
!theme plain
skinparam backgroundColor #FAFAFA
skinparam defaultFontName Arial

skinparam actor {
    BorderColor #0E6655
    BackgroundColor #A2D9CE
    FontColor #1A252F
    FontSize 13
    FontStyle bold
}

skinparam usecase {
    BorderColor #17A589
    BackgroundColor #E8F8F5
    FontColor #1A252F
    FontSize 12
    ArrowColor #5D6D7E
}

skinparam rectangle {
    BorderColor #17A589
    BorderThickness 2
    BackgroundColor #FDFEFE
    FontColor #0E6655
    FontSize 14
    FontStyle bold
}

title <size:17><b>UC10 - Quản Lý Sản Phẩm (Admin)</b></size>\n<color:#5D6D7E><size:12>CellphoneK E-Commerce App</size></color>

' ===================== ACTORS =====================
actor "Quản Trị Viên\n(Admin)" as Admin

' ===================== SYSTEM BOUNDARY =====================
rectangle "Hệ Thống Quản Lý Sản Phẩm" {
    usecase "UC10.1\nXem danh sách sản phẩm\n(Tìm kiếm theo tên,\nlọc theo danh mục, phân trang)" as UC10_1
    usecase "UC10.2\nThêm sản phẩm mới\n(Tên, Giá, Danh mục,\nMô tả, Hình ảnh, % Giảm giá)" as UC10_2
    usecase "UC10.3\nChỉnh sửa\nthông tin sản phẩm" as UC10_3
    usecase "UC10.4\nXóa sản phẩm" as UC10_4
}

' ===================== ASSOCIATIONS =====================
Admin --> UC10_1
Admin --> UC10_2
Admin --> UC10_3
Admin --> UC10_4

' ===================== RELATIONSHIPS =====================
UC10_3 .> UC10_1 : <<include>>
UC10_4 .> UC10_1 : <<include>>

' ===================== NOTES =====================
note right of UC10_2
  Các trường bắt buộc:
  - Tên sản phẩm
  - Giá sản phẩm
  Các trường tùy chọn:
  - Danh mục, Mô tả, Hình ảnh
  - Phần trăm giảm giá
end note

note right of UC10_4
  Cần xem danh sách trước
  mới có thể thực hiện
  chỉnh sửa hoặc xóa SP
end note

@enduml
