@startuml UC06_DatHangThanhToan
!theme plain
skinparam backgroundColor #FAFAFA
skinparam defaultFontName Arial

skinparam actor {
    BorderColor #784212
    BackgroundColor #FAD7A0
    FontColor #1A252F
    FontSize 13
    FontStyle bold
}

skinparam usecase {
    BorderColor #E67E22
    BackgroundColor #FEF5E7
    FontColor #1A252F
    FontSize 12
    ArrowColor #5D6D7E
}

skinparam rectangle {
    BorderColor #E67E22
    BorderThickness 2
    BackgroundColor #FDFEFE
    FontColor #784212
    FontSize 14
    FontStyle bold
}

title <size:17><b>UC06 - Đặt Hàng & Thanh Toán</b></size>\n<color:#5D6D7E><size:12>CellphoneK E-Commerce App</size></color>

' ===================== ACTORS =====================
actor "Khách Hàng\n(Customer)" as Customer
actor "Hệ thống Email\n(Email Service)" as EmailSvc

' ===================== SYSTEM BOUNDARY =====================
rectangle "Hệ Thống Đặt Hàng & Thanh Toán" {
    usecase "UC06.1\nĐặt hàng COD\n(Chọn SP, nhập địa chỉ, SĐT)" as UC06_1
    usecase "UC06.2\nÁp dụng mã\ngiảm giá (Coupon)" as UC06_2
    usecase "UC06.3\nSử dụng điểm thưởng\nđể giảm giá" as UC06_3
    usecase "UC06.4\nXem danh sách\nđơn hàng của tôi" as UC06_4
    usecase "UC06.5\nXem chi tiết\nđơn hàng" as UC06_5
    usecase "UC06.6\nHủy đơn hàng\n(Trong 30 phút,\ntrạng thái NEW/CONFIRMED)" as UC06_6
    usecase "UC06.7\nGửi yêu cầu hủy đơn\n(Khi đang PREPARING)" as UC06_7
}

' ===================== ASSOCIATIONS =====================
Customer --> UC06_1 : Chọn SP từ giỏ hàng
Customer --> UC06_4
Customer --> UC06_5
Customer --> UC06_6
Customer --> UC06_7
EmailSvc --> UC06_1 : Gửi email\nxác nhận đơn hàng

' ===================== RELATIONSHIPS =====================
UC06_2 .> UC06_1 : <<extend>>
UC06_3 .> UC06_1 : <<extend>>
UC06_5 .> UC06_4 : <<include>>
UC06_6 .> UC06_4 : <<extend>>
UC06_7 .> UC06_4 : <<extend>>

' ===================== NOTES =====================
note right of UC06_1
  Sau khi đặt hàng thành công:
  - Xóa SP khỏi giỏ hàng
  - Gửi thông báo trong app
  - Gửi email xác nhận
end note

note right of UC06_6
  Chỉ hủy được trong vòng 30 phút
  kể từ khi đặt hàng và khi
  trạng thái là NEW hoặc CONFIRMED
end note

note right of UC06_7
  Khi đơn đang PREPARING,
  gửi yêu cầu hủy lên Admin
  để Admin xử lý thủ công
end note

@enduml
