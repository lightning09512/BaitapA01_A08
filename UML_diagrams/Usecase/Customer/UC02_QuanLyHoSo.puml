@startuml UC02_QuanLyHoSo
!theme plain
skinparam backgroundColor #FAFAFA
skinparam defaultFontName Arial

skinparam actor {
    BorderColor #1E8449
    BackgroundColor #D5F5E3
    FontColor #1A252F
    FontSize 13
    FontStyle bold
}

skinparam usecase {
    BorderColor #27AE60
    BackgroundColor #EAFAF1
    FontColor #1A252F
    FontSize 12
    ArrowColor #5D6D7E
}

skinparam rectangle {
    BorderColor #27AE60
    BorderThickness 2
    BackgroundColor #FDFEFE
    FontColor #1E8449
    FontSize 14
    FontStyle bold
}

title <size:17><b>UC02 - Quản Lý Hồ Sơ Cá Nhân</b></size>\n<color:#5D6D7E><size:12>CellphoneK E-Commerce App</size></color>

' ===================== ACTORS =====================
actor "Khách Hàng\n(Customer)" as Customer

' ===================== SYSTEM BOUNDARY =====================
rectangle "Hệ Thống Quản Lý Hồ Sơ" {
    usecase "UC02.1\nXem hồ sơ cá nhân" as UC02_1
    usecase "UC02.2\nCập nhật hồ sơ\n(Avatar, Tên, SĐT,\nGiới tính, Sinh nhật)" as UC02_2
    usecase "UC02.3\nXem ví & điểm thưởng\n(Points + Coupons)" as UC02_3
    usecase "UC02.4\nXem thống kê\nđơn hàng cá nhân" as UC02_4
    usecase "UC02.5\nXem thông báo" as UC02_5
    usecase "UC02.6\nĐánh dấu đã đọc\ntất cả thông báo" as UC02_6
}

' ===================== ASSOCIATIONS =====================
Customer --> UC02_1
Customer --> UC02_2
Customer --> UC02_3
Customer --> UC02_4
Customer --> UC02_5
Customer --> UC02_6

' ===================== RELATIONSHIPS =====================
UC02_2 .> UC02_1 : <<include>>
UC02_6 .> UC02_5 : <<extend>>

' ===================== NOTES =====================
note right of UC02_3
  Hiển thị tổng điểm tích lũy
  và các mã giảm giá chưa dùng
  (nhận được sau khi review SP)
end note

note right of UC02_4
  Thống kê: đơn đang chờ,
  đang giao, đã nhận hàng
  cùng tổng tiền tương ứng
end note

@enduml
