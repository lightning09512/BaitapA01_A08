@startuml UC07_DanhGiaSanPham
!theme plain
skinparam backgroundColor #FAFAFA
skinparam defaultFontName Arial

skinparam actor {
    BorderColor #0E6655
    BackgroundColor #A2D9CE
    FontColor #1A252F
    FontSize 13
    FontStyle bold
}

skinparam usecase {
    BorderColor #17A589
    BackgroundColor #E8F8F5
    FontColor #1A252F
    FontSize 12
    ArrowColor #5D6D7E
}

skinparam rectangle {
    BorderColor #17A589
    BorderThickness 2
    BackgroundColor #FDFEFE
    FontColor #0E6655
    FontSize 14
    FontStyle bold
}

title <size:17><b>UC07 - Đánh Giá Sản Phẩm</b></size>\n<color:#5D6D7E><size:12>CellphoneK E-Commerce App</size></color>

' ===================== ACTORS =====================
actor "Khách Hàng\n(Customer)" as Customer

' ===================== SYSTEM BOUNDARY =====================
rectangle "Hệ Thống Đánh Giá Sản Phẩm" {
    usecase "UC07.1\nViết đánh giá sản phẩm\n(Chỉ sau khi đơn DELIVERED)" as UC07_1
    usecase "UC07.2\nXem tất cả đánh giá\ncủa sản phẩm" as UC07_2
    usecase "UC07.3\nNhận thưởng\n(+100 điểm +\nCoupon giảm giá 10%)" as UC07_3
}

' ===================== ASSOCIATIONS =====================
Customer --> UC07_1 : Chỉ có thể viết review\nkhi đã mua và nhận hàng
Customer --> UC07_2 : Xem trên trang\nchi tiết sản phẩm

' ===================== RELATIONSHIPS =====================
UC07_1 .> UC07_3 : <<include>>

' ===================== NOTES =====================
note right of UC07_1
  Điều kiện:
  - Đơn hàng có trạng thái DELIVERED
  - Sản phẩm chưa được đánh giá
    trong đơn hàng đó (isRated = false)
end note

note right of UC07_3
  Sau khi đánh giá thành công:
  - Cộng 100 điểm thưởng
  - Tạo mã coupon 10% (REVIEW + timestamp)
  - Gửi thông báo trong app
end note

@enduml
