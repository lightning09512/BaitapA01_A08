@startuml SD02_DangNhap
!theme plain
skinparam backgroundColor #FAFAFA
skinparam defaultFontName Arial
skinparam sequenceMessageAlign center

skinparam participant {
    BackgroundColor #EBF5FB
    BorderColor #2980B9
    FontColor #1A252F
    FontSize 12
}
skinparam actor {
    BackgroundColor #D5E8D4
    BorderColor #27AE60
    FontColor #1A252F
}
skinparam sequence {
    ArrowColor #2C3E50
    LifeLineBorderColor #AEB6BF
    LifeLineBackgroundColor #F2F3F4
    GroupBorderColor #8E44AD
    GroupBackgroundColor #F5EEF8
    GroupFontColor #6C3483
    DividerBackgroundColor #EAECEE
    DividerBorderColor #AEB6BF
}

title <size:16><b>SD02 - Đăng Nhập</b></size>\n<color:#5D6D7E><size:12>UC01.3 | CellphoneK</size></color>

actor "Người Dùng\n(Customer / Admin)" as User
participant "LoginScreen" as LoginScreen
participant "API Server\n(Express)" as Server
participant "AuthController" as AuthCtrl
participant "Database\n(MySQL)" as DB
participant "AsyncStorage\n(Local)" as Storage

== Luồng Đăng Nhập ==

User -> LoginScreen : Nhập username & password
LoginScreen -> Server : POST /login\n{username, password}
Server -> AuthCtrl : login(req, res)

AuthCtrl -> DB : User.findOne({username})
DB --> AuthCtrl : user (hoặc null)

alt Không tìm thấy user
    AuthCtrl --> Server : 401 "Sai tài khoản hoặc mật khẩu"
    Server --> LoginScreen : Error response
    LoginScreen --> User : Alert lỗi đăng nhập
else Sai mật khẩu
    AuthCtrl -> AuthCtrl : user.validPassword(password)\n→ false (Bcrypt compare)
    AuthCtrl --> Server : 401 "Sai tài khoản hoặc mật khẩu"
    Server --> LoginScreen : Error response
    LoginScreen --> User : Alert lỗi đăng nhập
else Tài khoản chưa xác minh
    AuthCtrl --> Server : 200 {requiresVerification: true,\nmessage: "Chưa xác minh email"}
    Server --> LoginScreen : Response cần xác minh
    LoginScreen --> User : Điều hướng sang\nVerifyAccountScreen
else Đăng nhập thành công
    AuthCtrl -> AuthCtrl : jwt.sign({id, username, role},\nSECRET_KEY)
    AuthCtrl --> Server : 200 {token, user, role}
    Server --> LoginScreen : Success response

    LoginScreen -> Storage : Lưu token vào AsyncStorage
    Storage --> LoginScreen : Done

    alt role = 'admin'
        LoginScreen --> User : Điều hướng sang\nAdmin Dashboard
    else role = 'customer'
        LoginScreen --> User : Điều hướng sang\nHome Screen
    end
end

== Luồng Xác Thực Token (các request sau) ==

note over LoginScreen, DB
    Mỗi request tiếp theo đính kèm:
    Headers: { Authorization: "Bearer <token>" }
    Server dùng authenticateToken middleware để verify JWT
    và truy vấn DB lấy role chính xác
end note

@enduml
