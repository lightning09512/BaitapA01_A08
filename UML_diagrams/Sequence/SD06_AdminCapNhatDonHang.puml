@startuml SD06_AdminCapNhatDonHang
!theme plain
skinparam backgroundColor #FAFAFA
skinparam defaultFontName Arial
skinparam sequenceMessageAlign center

skinparam participant {
    BackgroundColor #F5EEF8
    BorderColor #8E44AD
    FontColor #1A252F
    FontSize 12
}
skinparam actor {
    BackgroundColor #D2B4DE
    BorderColor #6C3483
    FontColor #1A252F
}
skinparam sequence {
    ArrowColor #2C3E50
    LifeLineBorderColor #AEB6BF
    LifeLineBackgroundColor #F2F3F4
    GroupBorderColor #8E44AD
    GroupBackgroundColor #F5EEF8
    GroupFontColor #6C3483
    DividerBackgroundColor #EAECEE
    DividerBorderColor #AEB6BF
}

title <size:16><b>SD06 - Admin Cập Nhật Trạng Thái Đơn Hàng</b></size>\n<color:#5D6D7E><size:12>UC11.2 | CellphoneK</size></color>

actor "Quản Trị Viên\n(Admin)" as Admin
actor "Khách Hàng\n(Customer)" as Customer
participant "AdminOrdersScreen" as AdminScreen
participant "API Server\n(Express + Auth)" as Server
participant "AdminController" as AdminCtrl
participant "Database\n(MySQL)" as DB

== Bước 1: Xem Danh Sách Đơn Hàng ==

Admin -> AdminScreen : Mở màn hình Quản lý Đơn hàng
AdminScreen -> Server : GET /admin/orders?status=ALL\n(Bearer token - Admin role)
Server -> Server : authenticateToken()\nrequireAdmin()
Server -> AdminCtrl : getAllOrders(req, res)
AdminCtrl -> DB : Order.findAndCountAll(\ninclude: [OrderItem, User],\norder: createdAt DESC)
DB --> AdminCtrl : orders list
AdminCtrl --> Server : 200 {items, total, page}
Server --> AdminScreen : Danh sách đơn hàng
AdminScreen --> Admin : Hiển thị danh sách\nvới bộ lọc theo trạng thái

== Bước 2: Cập Nhật Trạng Thái ==

Admin -> AdminScreen : Chọn đơn hàng\nvà chọn trạng thái mới
AdminScreen -> Server : POST /admin/orders/status\n{orderId, newStatus}\n(Bearer token)
Server -> Server : authenticateToken()\nrequireAdmin()
Server -> AdminCtrl : updateOrderStatus(req, res)

AdminCtrl -> AdminCtrl : Validate newStatus in\n[NEW, CONFIRMED, PREPARING,\nSHIPPING, DELIVERED, CANCELLED]

AdminCtrl -> DB : Order.findByPk(orderId)
DB --> AdminCtrl : order

AdminCtrl -> DB : order.status = newStatus\norder.save()

== Bước 3: Xử Lý Đặc Biệt Khi DELIVERED ==

alt newStatus = 'DELIVERED'
    AdminCtrl -> DB : OrderItem.findAll({orderId})
    DB --> AdminCtrl : items

    loop Mỗi sản phẩm trong đơn
        AdminCtrl -> DB : Product.findByPk(item.productId)
        AdminCtrl -> DB : product.soldQuantity += item.quantity\nproduct.save()
    end

    AdminCtrl -> DB : User.findByPk(order.userId)
    DB --> AdminCtrl : customer user

    AdminCtrl -> DB : Notification.create(\n{userId: user.username,\ntitle: 'Đơn hàng đã giao thành công!',\nmessage: 'Đơn #XXXXXX đã được\ngiao thành công. Cảm ơn!'})
    DB --> AdminCtrl : notification created

    note right of Customer
        Khách hàng nhận được
        thông báo trong app
        khi mở NotificationScreen
    end note
end

alt newStatus = 'CONFIRMED'
    AdminCtrl -> DB : order.confirmedAt = now()\norder.save()
end

alt newStatus = 'CANCELLED'
    AdminCtrl -> DB : order.cancelledAt = now()\norder.save()
end

AdminCtrl --> Server : 200 {message, order}
Server --> AdminScreen : Success response
AdminScreen --> Admin : Cập nhật UI trạng thái đơn

@enduml
