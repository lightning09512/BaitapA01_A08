@startuml SD09_ToggleYeuThich
!theme plain
skinparam backgroundColor #FAFAFA
skinparam defaultFontName Arial
skinparam sequenceMessageAlign center

skinparam participant {
    BackgroundColor #FDEDEC
    BorderColor #E74C3C
    FontColor #1A252F
    FontSize 12
}
skinparam actor {
    BackgroundColor #D5E8D4
    BorderColor #27AE60
    FontColor #1A252F
}
skinparam sequence {
    ArrowColor #2C3E50
    LifeLineBorderColor #AEB6BF
    LifeLineBackgroundColor #F2F3F4
    GroupBorderColor #E74C3C
    GroupBackgroundColor #FDEDEC
    GroupFontColor #922B21
    DividerBackgroundColor #EAECEE
    DividerBorderColor #AEB6BF
}

title <size:16><b>SD09 - Toggle Yêu Thích Sản Phẩm</b></size>\n<color:#5D6D7E><size:12>UC04.1 | CellphoneK</size></color>

actor "Khách Hàng" as User
participant "ProductDetail\nScreen" as DetailScreen
participant "API Server\n(Express)" as Server
participant "UserController" as UserCtrl
participant "Database\n(MySQL)" as DB

== Kiểm Tra Trạng Thái Ban Đầu ==

DetailScreen -> Server : GET /favorites/check/:productId\n(Bearer token)
Server -> UserCtrl : checkFavorite(req, res)
UserCtrl -> DB : user.hasFavorite(product)
DB --> UserCtrl : isFavorite (true/false)
UserCtrl --> Server : 200 {isFavorite}
Server --> DetailScreen : Trạng thái yêu thích hiện tại
DetailScreen --> User : Hiển thị icon ❤️ (đỏ = đã thích)\nhoặc 🤍 (trống = chưa thích)

== Toggle Yêu Thích ==

User -> DetailScreen : Nhấn icon ❤️ / 🤍
DetailScreen -> Server : POST /favorites/toggle\n{productId}\n(Bearer token)
Server -> UserCtrl : toggleFavorite(req, res)

UserCtrl -> DB : User.findOne({username})
UserCtrl -> DB : Product.findByPk(productId)
UserCtrl -> DB : user.hasFavorite(product)
DB --> UserCtrl : hasFav (true/false)

alt Đã yêu thích → Bỏ yêu thích
    UserCtrl -> DB : user.removeFavorite(product)
    DB --> UserCtrl : Done
    UserCtrl -> DB : user.getFavorites({attributes: ['id']})
    DB --> UserCtrl : updatedFavoriteIds
    UserCtrl --> Server : 200 {isFavorite: false, favorites: [...ids]}
    Server --> DetailScreen : Response
    DetailScreen --> User : Đổi icon sang 🤍\n(chưa yêu thích)
else Chưa yêu thích → Thêm yêu thích
    UserCtrl -> DB : user.addFavorite(product)
    DB --> UserCtrl : Done
    UserCtrl -> DB : user.getFavorites({attributes: ['id']})
    DB --> UserCtrl : updatedFavoriteIds
    UserCtrl --> Server : 200 {isFavorite: true, favorites: [...ids]}
    Server --> DetailScreen : Response
    DetailScreen --> User : Đổi icon sang ❤️\n(đã yêu thích)
end

== Xem Danh Sách Yêu Thích ==

User -> DetailScreen : Vào FavoritesScreen
DetailScreen -> Server : GET /favorites\n(Bearer token)
Server -> UserCtrl : getFavorites(req, res)
UserCtrl -> DB : User.findOne(include: ['Favorites'])
DB --> UserCtrl : danh sách SP yêu thích
UserCtrl --> Server : 200 [products]
Server --> DetailScreen : Danh sách SP yêu thích
DetailScreen --> User : Hiển thị grid SP yêu thích

@enduml
