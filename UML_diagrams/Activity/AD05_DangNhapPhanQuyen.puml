@startuml AD05_DangNhapPhanQuyen
!theme plain
skinparam backgroundColor #FAFAFA
skinparam defaultFontName Arial

skinparam activity {
    BackgroundColor #EBF5FB
    BorderColor #2980B9
    FontColor #1A252F
    FontSize 12
    DiamondBackgroundColor #FEF9E7
    DiamondBorderColor #D4AC0D
    DiamondFontColor #1A252F
    StartColor #1A5276
    EndColor #1A5276
    BarColor #2980B9
}
skinparam arrow {
    Color #2C3E50
    FontColor #5D6D7E
    FontSize 11
}
skinparam swimlane {
    BorderColor #AEB6BF
    TitleFontSize 13
    TitleFontStyle bold
}

title <size:16><b>AD05 - Đăng Nhập & Phân Quyền</b></size>\n<color:#5D6D7E><size:12>UC01.3 | CellphoneK</size></color>


|Người Dùng|
start
:Mở ứng dụng CellphoneK;

|Hệ thống (Server)|
if (Đã có token\ntrong AsyncStorage?) then (Có)
    :Verify JWT token;
    if (Token hợp lệ?) then (Có)
        :Lấy role từ Database;
        if (role = 'admin'?) then (Có)
            |Màn hình Ứng dụng|
            :Điều hướng sang\nAdmin Dashboard;
            stop
        else (Không - customer)
            |Màn hình Ứng dụng|
            :Điều hướng sang\nHome Screen;
            stop
        endif
    else (Không - hết hạn/invalid)
        :Xóa token cũ;
    endif
else (Không)
endif

|Màn hình Ứng dụng|
:Hiển thị màn hình\nIntro / Login;

|Người Dùng|
:Nhập username & password;
:Nhấn "Đăng nhập";

|Hệ thống (Server)|
:Tìm user\ntheo username trong DB;

if (Tìm thấy user?) then (Không)
    |Màn hình Ứng dụng|
    :Hiển thị lỗi\n"Sai tài khoản hoặc mật khẩu";
    |Người Dùng|
    :Nhập lại thông tin;
    stop
else (Có)
endif

:So sánh password\n(Bcrypt.compare);

if (Mật khẩu đúng?) then (Không)
    |Màn hình Ứng dụng|
    :Hiển thị lỗi\n"Sai tài khoản hoặc mật khẩu";
    stop
else (Có)
endif

if (isVerified = true?) then (Không)
    |Màn hình Ứng dụng|
    :Chuyển sang màn hình\nXác minh OTP;
    stop
else (Có)
endif

|Hệ thống (Server)|
:Tạo JWT Token\n{id, username, role};

|Màn hình Ứng dụng|
:Lưu token vào AsyncStorage;

if (role = 'admin'?) then (Có)
    :Điều hướng sang\nAdmin Dashboard\n(AdminDashboardScreen);
else (Không - customer)
    :Điều hướng sang\nHome Screen\n(HomeScreen);
endif
stop

@enduml
