@startuml AD01_DangKyXacMinhOTP
!theme plain
skinparam backgroundColor #FAFAFA
skinparam defaultFontName Arial

skinparam activity {
    BackgroundColor #EBF5FB
    BorderColor #2980B9
    FontColor #1A252F
    FontSize 12
    DiamondBackgroundColor #FEF9E7
    DiamondBorderColor #D4AC0D
    DiamondFontColor #1A252F
    StartColor #2C3E50
    EndColor #2C3E50
    BarColor #2980B9
}
skinparam arrow {
    Color #2C3E50
    FontColor #5D6D7E
    FontSize 11
}
skinparam swimlane {
    BorderColor #AEB6BF
    TitleFontSize 13
    TitleFontStyle bold
}

title <size:16><b>AD01 - Đăng Ký Tài Khoản & Xác Minh OTP</b></size>\n<color:#5D6D7E><size:12>UC01.1 + UC01.2 | CellphoneK</size></color>


|Khách Hàng|
start
:Mở màn hình Đăng ký;
:Nhập Username, Email, Password;

|Hệ thống (Server)|
:Validate form\n(độ dài, format email);

if (Dữ liệu hợp lệ?) then (Không)
    |Khách Hàng|
    :Hiển thị lỗi\nngay dưới ô nhập;
    stop
else (Có)
endif

:Kiểm tra tài khoản đã\nxác minh với username/email;

if (Tài khoản đã tồn tại\n(isVerified = true)?) then (Có)
    |Khách Hàng|
    :Hiển thị thông báo lỗi\n"Tài khoản/Email đã tồn tại";
    stop
else (Không)
endif

|Hệ thống (Server)|
:Xóa bản ghi CHƯA XÁC MINH\nbị trùng (dọn dẹp đăng ký bỏ dở);
:Tạo mã OTP 6 số ngẫu nhiên;
:Lưu User mới vào DB\n(isVerified = false, verifyOtp = otp);

|Email Service|
:Gửi email chứa mã OTP\nđến địa chỉ email đăng ký;

|Khách Hàng|
:Nhận thông báo\n"Kiểm tra email để lấy OTP";
:Mở email & đọc mã OTP;
:Nhập mã OTP 6 số\nvào màn hình Xác minh;

|Hệ thống (Server)|
:Tìm kiếm user\ntheo email trong DB;

if (Tìm thấy user?) then (Không)
    |Khách Hàng|
    :Hiển thị lỗi\n"Không tìm thấy tài khoản";
    stop
else (Có)
endif

if (OTP có đúng không?) then (Không)
    |Khách Hàng|
    :Hiển thị lỗi\n"Mã OTP không đúng";
    :Nhập lại mã OTP;
    stop
else (Có)
endif

|Hệ thống (Server)|
:Cập nhật: isVerified = true\nverifyOtp = null;

|Khách Hàng|
:Hiển thị "Xác minh thành công!";
:Chuyển sang màn hình Đăng nhập;
stop

@enduml
