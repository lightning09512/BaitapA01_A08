@startuml AD04_DanhGiaNhanThuong
!theme plain
skinparam backgroundColor #FAFAFA
skinparam defaultFontName Arial

skinparam activity {
    BackgroundColor #E8F8F5
    BorderColor #17A589
    FontColor #1A252F
    FontSize 12
    DiamondBackgroundColor #FEF9E7
    DiamondBorderColor #D4AC0D
    DiamondFontColor #1A252F
    StartColor #0E6655
    EndColor #0E6655
    BarColor #17A589
}
skinparam arrow {
    Color #2C3E50
    FontColor #5D6D7E
    FontSize 11
}
skinparam swimlane {
    BorderColor #AEB6BF
    TitleFontSize 13
    TitleFontStyle bold
}

title <size:16><b>AD04 - Viết Đánh Giá Sản Phẩm & Nhận Thưởng</b></size>\n<color:#5D6D7E><size:12>UC07.1 + UC07.3 | CellphoneK</size></color>

|Khách Hàng|
start
:Mở màn hình Đơn hàng của tôi;
:Chọn đơn hàng\ncó trạng thái DELIVERED;

|Hệ thống (Server)|
if (Đơn hàng có sản phẩm\nchưa được đánh giá\n(isRated = false)?) then (Không)
    |Khách Hàng|
    :Không hiển thị nút\n"Viết đánh giá";
    stop
else (Có)
endif

|Khách Hàng|
:Nhấn "Viết đánh giá"\ntrên sản phẩm trong đơn;
:Mở màn hình\nWriteReviewScreen;
:Chọn số sao (1 - 5 ⭐);
:Nhập nội dung nhận xét;
:Nhấn "Gửi đánh giá";

|Hệ thống (Server)|
:Kiểm tra điều kiện:\n- Đơn có status = DELIVERED?\n- OrderItem có isRated = false?;

if (Hợp lệ để đánh giá?) then (Không)
    |Khách Hàng|
    :Hiển thị lỗi\n"Bạn đã đánh giá sản phẩm này\nrồi hoặc đơn hàng chưa hoàn tất";
    stop
else (Có)
endif

|Hệ thống (Server)|
:Đánh dấu OrderItem:\nisRated = true;
:Tạo bản ghi Review mới\n(rating, comment, userId, productId);

fork
    :Cộng 100 điểm thưởng\nvào user.points;
fork again
    :Tạo Coupon giảm giá 10%\n(code: REVIEW + timestamp);
fork again
    :Tạo Notification\n"Bạn được thưởng 100 điểm\nvà mã giảm giá 10%";
end fork

|Khách Hàng|
:Nhận thông báo\n"Đánh giá thành công!\n+100 điểm & coupon 10%";
:Quay về màn hình\nchi tiết sản phẩm;
:Review hiển thị\ntrên trang sản phẩm;
stop

@enduml
