@startuml
left to right direction
skinparam packageStyle rectangle

actor "Người dùng" as User
actor "Quản trị viên" as Admin

package "Hệ thống Bán hàng CellphoneK" {
    
    package "Tài khoản" {
        usecase "Đăng ký tài khoản" as UC_Reg
        usecase "Xác thực OTP" as UC_Verify
        usecase "Đăng nhập" as UC_Login
        usecase "Quên mật khẩu" as UC_Forgot
        usecase "Cập nhật hồ sơ" as UC_Profile
        
        UC_Reg ..> UC_Verify : include
    }

    package "Mua sắm" {
        usecase "Tìm kiếm sản phẩm" as UC_Search
        usecase "Lọc sản phẩm" as UC_Filter
        usecase "Xem chi tiết & Cấu hình" as UC_Details
        usecase "Chọn biến thể" as UC_Variant
        usecase "Giỏ hàng" as UC_Cart
        usecase "Yêu thích" as UC_Fav
    }

    package "Giao dịch" {
        usecase "Đặt hàng COD" as UC_Order
        usecase "Theo dõi đơn hàng" as UC_Track
        usecase "Hủy đơn hàng" as UC_Cancel
        usecase "Đánh giá" as UC_Review
        usecase "Chat hỗ trợ" as UC_Chat
    }

    package "Quản trị" {
        usecase "Thống kê doanh thu" as UC_Dash
        usecase "Quản lý sản phẩm" as UC_Manage_Prod
        usecase "Quản lý đơn hàng" as UC_Manage_Order
        usecase "Quản lý người dùng" as UC_Manage_User
        usecase "Hỗ trợ khách hàng (Chat)" as UC_Admin_Chat
    }
}

User --> UC_Reg
User --> UC_Login
User --> UC_Search
User --> UC_Cart
User --> UC_Order
User --> UC_Chat

Admin --> UC_Dash
Admin --> UC_Manage_Prod
Admin --> UC_Manage_Order
Admin --> UC_Admin_Chat
Admin --> UC_Login

@enduml
