@startuml
autonumber

participant "Người dùng" as User
participant "App (Giỏ hàng)" as App
participant "Order Controller" as Controller
database "MySQL" as DB

== Đặt hàng (Checkout COD) ==

User -> App : Nhấn Đặt hàng
App -> Controller : POST /api/orders/checkout-cod
group Giao dịch (Transaction)
    Controller -> DB : Kiểm tra tồn kho (ProductVariants)
    DB --> Controller : Kết quả

    alt [Không đủ hàng]
        Controller -> App : Trả về lỗi 400
    else [Hợp lệ]
        Controller -> DB : Insert Orders
        Controller -> DB : Insert OrderItems
        Controller -> DB : Update Stock (ProductVariants)
        Controller -> DB : Delete CartItems
        DB --> Controller : Thành công
        Controller -> App : Trả về 200
        App -> User : Hiện thông báo thành công
    end
end
@enduml
